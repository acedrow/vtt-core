{
  "name": "@gaem/hellpiercers-content",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./register-client": {
      "types": "./src/register-client.ts",
      "import": "./src/register-client.ts",
      "default": "./src/register-client.ts"
    },
    "./tiles": {
