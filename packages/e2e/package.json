  "type": "module",
  "scripts": {
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright-browsers\" playwright install chromium",
    "test:e2e": "E2E_CLIENT_URL=\"${E2E_CLIENT_URL:-http://localhost:5174}\" E2E_API_URL=\"${E2E_API_URL:-http://localhost:3002}\" PORT=\"${PORT:-3002}\" PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright-browsers\" playwright test",
    "test:e2e:ui": "E2E_CLIENT_URL=\"${E2E_CLIENT_URL:-http://localhost:5174}\" E2E_API_URL=\"${E2E_API_URL:-http://localhost:3002}\" PORT=\"${PORT:-3002}\" PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright-browsers\" playwright test --ui",
    "test:e2e:headed": "E2E_CLIENT_URL=\"${E2E_CLIENT_URL:-http://localhost:5174}\" E2E_API_URL=\"${E2E_API_URL:-http://localhost:3002}\" PORT=\"${PORT:-3002}\" PLAYWRIGHT_BROWSERS_PATH=\"$PWD/.playwright-browsers\" playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3"
  }
}
