{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@gaem/client/content-pack": ["./src/client-content-pack.ts"],
      "@gaem/client/*": ["./src/*"],
      "@gaem/hellpiercers-content/tiles": [
        "../../node_modules/@gaem/hellpiercers-content/src/client/tiles/index.ts"
      ],
      "@gaem/hellpiercers-content/combat-ui": [
        "../../node_modules/@gaem/hellpiercers-content/src/combat-ui.ts"
      ],
      "@gaem/hellpiercers-content/register": [
        "../../node_modules/@gaem/hellpiercers-content/src/register.ts"
      ],
      "@gaem/hellpiercers-content/register-client": [
        "../../node_modules/@gaem/hellpiercers-content/src/register-client.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../../node_modules/@gaem/hellpiercers-content/src/client/**/*.ts",
    "../../node_modules/@gaem/hellpiercers-content/src/client/**/*.vue",
    "../../node_modules/@gaem/hellpiercers-content/src/register-client.ts",
    "../../node_modules/@gaem/hellpiercers-content/src/combat-ui.ts",
    "../../node_modules/@gaem/hellpiercers-content/src/combat/**/*.ts"
  ],
  "exclude": [
    "../../node_modules/@gaem/hellpiercers-content/src/**/*.test.ts"
  ]
}
